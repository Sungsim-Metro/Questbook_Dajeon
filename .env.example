# NAVER Cloud Platform Maps 인증 정보다.
# 이 파일을 .env로 복사한 뒤 본인 값을 입력한다.
# NAVER_MAPS_API_KEY_ID는 Dynamic Map SDK 로딩을 위해 브라우저로 전달된다.
NAVER_MAPS_API_KEY_ID=
# NAVER_MAPS_API_KEY는 Geocoding, Reverse Geocoding, 향후 Directions 5 프록시 호출을 위해 로컬 서버에만 둔다.
NAVER_MAPS_API_KEY=

# 선택적 로컬 개발 서버 설정이다.
QUESTBOOK_HOST=0.0.0.0
QUESTBOOK_PORT=8000
QUESTBOOK_PUBLIC_URL=http://100.87.116.106:8000
