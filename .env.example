# NAVER Cloud Platform Maps credentials.
# Copy this file to .env and fill in your own values.
# NAVER_MAPS_API_KEY_ID is sent to the browser for Dynamic Map SDK loading.
NAVER_MAPS_API_KEY_ID=
# NAVER_MAPS_API_KEY stays on the local server for Geocoding, Reverse Geocoding, and future Directions 5 proxy calls.
NAVER_MAPS_API_KEY=

# Optional local development server settings.
QUESTBOOK_HOST=0.0.0.0
QUESTBOOK_PORT=8000
QUESTBOOK_PUBLIC_URL=http://100.87.116.106:8000
